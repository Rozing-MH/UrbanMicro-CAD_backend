# 本地开发用 Supabase 连接配置
# 复制此文件为 application-local.yml 并填入真实值
# application-local.yml 已加入 .gitignore，不会被提交
#
# 启动命令：
#   mvn spring-boot:run -Dspring-boot.run.profiles=local

spring:
  datasource:
    url: jdbc:postgresql://db.zmxmndexptzuynyuqitb.supabase.co:5432/postgres
    username: postgres
    password: YOUR_SUPABASE_DB_PASSWORD_HERE

app:
  jwt:
    secret: YOUR_JWT_SECRET_HERE_AT_LEAST_32_CHARS
